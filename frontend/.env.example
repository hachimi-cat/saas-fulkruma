# Fulkruma frontend — copy to .env.local for dev.
# In dev, you can also `set -a; source /root/.config/forjio/fulkruma-secrets.env; set +a` before `npm run dev`.

# Public (browser-visible) — used by the Phase B placeholder UI only
NEXT_PUBLIC_API_URL=http://localhost:4140
NEXT_PUBLIC_BRAND_NAME=Fulkruma

# Public (browser-visible) — Huudis issuer for the social-provider
# discovery call on the login page. Defaults to https://huudis.com if
# unset. Override for local huudis dev (e.g. http://localhost:4040).
NEXT_PUBLIC_HUUDIS_ISSUER=https://huudis.com

# Public (browser-visible) — Google Maps key for the shipping origin
# location picker (Places API New + Maps JavaScript API). Mint at
# console.cloud.google.com → Maps Platform → APIs & Services → Credentials.
# Enable: "Places API (New)" + "Maps JavaScript API". Restrict by HTTP
# referrer to dev-machine.taila71a7b.ts.net + fulkruma.com.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=REPLACE_ME_GOOGLE_MAPS_API_KEY

# Server-only — Huudis OIDC (Phase C). Source from
# /root/.config/forjio/fulkruma-secrets.env (HUUDIS_CLIENT_FULKRUMA seeded
# by saas-huudis seed-first-party-clients.ts).
HUUDIS_ISSUER=https://huudis.com
HUUDIS_CLIENT_ID=fulkruma
HUUDIS_CLIENT_SECRET=REPLACE_ME
HUUDIS_ALLOWED_USER_ID=REPLACE_ME

# Server-only — portal callback URL (must match the OIDC client's
# registered redirect_uri in Huudis).
FULKRUMA_PORTAL_URL=http://localhost:3140

# Server-only — HMAC for the fulkruma_session cookie. Generate via
# `openssl rand -hex 32`. Different per environment.
SESSION_COOKIE_SECRET=REPLACE_ME

# Server-only — backend API URL (used by server actions / proxies).
FULKRUMA_API_URL=http://localhost:4140
