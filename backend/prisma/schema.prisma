// Fulkruma — stock + warehouses + shipping + addresses + delivery + licenses.
// Extracted from saas-storlaunch (M5). Per ADR-0001 (one DB per service),
// references to Storlaunch / Plugipay / Huudis entities are kept as bare
// string IDs — no FK relations across service boundaries. Cross-service
// state arrives via the outbox event bus (ADR-0006).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// OUTBOX (ADR-0006)
// =============================================================================

model OutboxEvent {
  id          String    @id // ULID, globally unique (evt_*)
  type        String    // e.g. "fulkruma.shipment.created.v1"
  accountId   String?
  occurredAt  DateTime
  data        Json
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  publishedAt DateTime?
  attempts    Int       @default(0)
  lastError   String?

  @@index([publishedAt, createdAt], name: "ix_outbox_unpublished")
  @@index([accountId, type])
  @@map("outbox_events")
}

model ProcessedEvent {
  eventId     String   @id
  processedAt DateTime @default(now())

  @@map("processed_events")
}

// =============================================================================
// DIRECT-TENANT BILLING (Plugipay-managed)
// =============================================================================
// Direct fulkruma tenants pay through plugipay.com. Pattern matches
// linksnap/huudis: plugipay holds the canonical Customer + Subscription +
// Invoice; we mirror just enough state locally (plan + period bounds + ids)
// to gate features and render /dashboard/billing without a network call.
// Webhook receiver at /webhooks/plugipay flips status on invoice.paid +
// subscription.canceled.

enum FulkrumaPlan {
  FREE
  STARTER
  GROWTH
  SCALE
}

enum FulkrumaSubscriptionStatus {
  ACTIVE
  CANCELING
  CANCELED
  PAST_DUE
  INCOMPLETE
}

model Subscription {
  accountId              String                     @id
  plan                   FulkrumaPlan               @default(FREE)
  status                 FulkrumaSubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAt               DateTime?
  plugipayCustomerId     String?
  plugipaySubscriptionId String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  invoices Invoice[]

  @@index([plugipayCustomerId])
  @@index([plugipaySubscriptionId])
}

model Invoice {
  id                String       @id @default(cuid())
  accountId         String
  plugipayInvoiceId String       @unique
  plan              FulkrumaPlan
  amount            Int
  currency          String       @default("IDR")
  status            String
  paidAt            DateTime?
  receiptUrl        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  subscription Subscription @relation(fields: [accountId], references: [accountId], onDelete: Cascade)

  @@index([accountId, createdAt])
}

model MonthlyUsage {
  accountId       String
  year            Int
  month           Int
  ordersFulfilled Int      @default(0)
  shipmentsCreated Int     @default(0)
  licensesIssued  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@id([accountId, year, month])
  @@index([accountId])
}

// =============================================================================
// ENUMS
// =============================================================================

// 1:1 with Biteship's published tracking-status list (F-003) — see
// https://biteship.com/id/docs/api/trackings/status. We preserve every
// status Biteship emits so the merchant + buyer timeline reflects
// exactly what happened with the parcel.
//
//   pending  — internal, pre-courier-confirm
//   failed   — internal, adapter-level error before Biteship answered
//
// The previous `in_transit` value was our own invention used as a
// catch-all for on_hold + dropping_off; removed since we now keep
// those granular states directly.
enum ShipmentStatus {
  pending
  confirmed
  scheduled
  allocated
  picking_up
  picked_up
  dropping_off
  on_hold
  return_in_transit
  delivered
  rejected
  rejected_by_recipient
  returned
  cancelled
  courier_not_found
  disposed
  failed
}

enum LicenseStatus {
  active
  revoked
}

enum StockMovementReason {
  manual_adjust
  checkout_reserve
  checkout_commit
  checkout_release
  refund_restock
  transfer_in
  transfer_out
  damaged
  returned_to_supplier
  initial_stock
  import
}

// =============================================================================
// ADDRESS BOOK
// =============================================================================

/// Buyer address book per merchant. customerId is a Storlaunch buyer ID
/// (or, post-Storlaunch, a Huudis end-user ID). accountId scopes per merchant.
model CustomerAddress {
  id                 String   @id @default(cuid())
  customerId         String
  accountId          String
  label              String
  contactName        String
  contactPhone       String
  email              String?
  address            String   @db.Text
  note               String?
  postalCode         String?
  areaId             String?
  lat                Float?
  lng                Float?
  biteshipLocationId String?
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([customerId])
  @@index([accountId, customerId])
  @@index([customerId, isDefault])
}

// =============================================================================
// CATALOGUE
// =============================================================================

enum ProductType {
  physical
  digital
  license
}

/// Fulkruma's own product catalogue. When fulkruma runs as a Storlaunch
/// module, products sync via webhook and `externalRef` stores the
/// originating Storlaunch productId. When fulkruma runs standalone,
/// merchants create products directly through the portal.
model Product {
  id             String      @id @default(cuid())
  accountId      String
  name           String
  sku            String?     // merchant-defined external SKU
  description    String?     @db.Text
  type           ProductType @default(physical)
  // shipping attributes — only meaningful when type=physical
  weight         Int?        // grams
  length         Int?        // cm
  width          Int?        // cm
  height         Int?        // cm
  // license attrs — only meaningful when type=license
  licenseEnabled Boolean     @default(false)
  maxActivations Int         @default(1)
  // origin / external reference (Storlaunch productId, etc.)
  externalRef    String?     // e.g. "prod_storlaunch_..."
  externalSource String?     // e.g. "storlaunch"
  archived       Boolean     @default(false)
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  variants ProductVariant[]

  @@unique([accountId, externalSource, externalRef])
  @@index([accountId])
  @@index([accountId, archived])
  @@index([sku])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  sku               String?  // merchant-defined SKU code
  name              String   // "Red / M", or "Default" for non-varianted
  priceCents        Int      @default(0) // optional retail price (informational; payment is in plugipay)
  costCents         Int?
  lowStockThreshold Int?     // alerts trigger below this; null = disabled
  weight            Int?     // overrides Product.weight when set
  isDefault         Boolean  @default(false)
  archived          Boolean  @default(false)
  externalRef       String?  // e.g. "var_storlaunch_..."
  externalSource    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, externalSource, externalRef])
  @@index([productId])
  @@index([sku])
}

// =============================================================================
// INVENTORY
// =============================================================================

model Warehouse {
  id        String   @id @default(cuid())
  accountId String
  name      String
  address   String?  @db.Text
  city      String?
  postal    String?
  lat       Float?
  lng       Float?
  phone     String?
  isDefault Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stock        VariantStock[]
  movements    StockMovement[]
  reservations StockReservation[]

  @@index([accountId])
  @@index([accountId, isDefault])
}

/// Per-variant stock per warehouse. variantId is a Storlaunch ProductVariant ID
/// (cross-service reference — no FK).
model VariantStock {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId])
  @@index([variantId])
  @@index([warehouseId])
}

model StockMovement {
  id          String              @id @default(cuid())
  variantId   String
  warehouseId String
  delta       Int
  reason      StockMovementReason
  referenceId String?
  note        String?
  createdAt   DateTime            @default(now())
  createdBy   String?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([warehouseId])
  @@index([variantId, createdAt])
  @@index([referenceId])
}

/// Soft holds during an open checkout. Released on expiry/cancel,
/// committed when payment.success arrives over the outbox.
model StockReservation {
  id                String    @id @default(cuid())
  variantId         String
  warehouseId       String
  quantity          Int
  checkoutSessionId String
  expiresAt         DateTime
  consumedAt        DateTime?
  releasedAt        DateTime?
  createdAt         DateTime  @default(now())

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([checkoutSessionId])
  @@index([variantId, warehouseId])
  @@index([expiresAt])
}

// =============================================================================
// DIGITAL FULFILMENT — licenses + delivery
// =============================================================================

model License {
  id             String        @id @default(cuid())
  accountId      String
  productId      String
  customerId     String
  key            String        @unique
  status         LicenseStatus @default(active)
  activations    Int           @default(0)
  maxActivations Int           @default(1)
  expiresAt      DateTime?
  // Source-system back-reference for partner integrations. Storlaunch
  // populates these with ('storlaunch', <checkoutSessionId>) so the
  // round-trip from storlaunch UI → fulkruma data → back to storlaunch
  // is inspectable. Direct fulkruma tenants leave them null.
  externalSource String?
  externalRef    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  licenseActivations LicenseActivation[]

  @@index([accountId])
  @@index([productId])
  @@index([customerId])
  @@index([key])
  @@index([status])
  @@index([accountId, externalSource, externalRef])
}

model LicenseActivation {
  id            String    @id @default(cuid())
  licenseId     String
  instanceId    String
  activatedAt   DateTime  @default(now())
  deactivatedAt DateTime?

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, instanceId])
  @@index([licenseId])
  @@index([instanceId])
}

/// Per-checkout digital download tracking.
model Delivery {
  id                String   @id @default(cuid())
  accountId         String
  productId         String
  customerId        String
  checkoutSessionId String   @unique
  downloadCount     Int      @default(0)
  maxDownloads      Int      @default(5)
  expiresAt         DateTime
  // Source-system back-reference (see License).
  externalSource   String?
  externalRef      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([accountId])
  @@index([productId])
  @@index([customerId])
  @@index([expiresAt])
  @@index([accountId, externalSource, externalRef])
}

// =============================================================================
// SHIPPING — Biteship-backed
// =============================================================================

model Shipment {
  id                  String         @id @default(cuid())
  accountId           String
  productId           String?
  checkoutSessionId   String?
  customerId          String?
  customerEmail       String?
  // Biteship two-step booking (F-004). Shipments now start as drafts
  // (no charge, no courier dispatch) so merchants can prep / cook / pack
  // before the driver is allocated. `biteshipDraftOrderId` is set on
  // shipment.create; `biteshipOrderId` only populates after the merchant
  // calls confirm-pickup. Either one (but not both) being present is
  // valid; both present after confirm.
  biteshipDraftOrderId String?        @unique
  biteshipOrderId     String?         @unique
  biteshipTrackingId  String?
  waybillId           String?
  courierCode         String
  courierServiceCode  String
  courierType         String
  status              ShipmentStatus @default(pending)
  trackingUrl         String?
  labelUrl            String?
  price               Int
  insurance           Int            @default(0)
  insured             Boolean        @default(false)
  originSnapshot      Json
  destinationSnapshot Json
  items               Json
  cancelReason        String?
  // Source-system back-reference (see License).
  externalSource      String?
  externalRef         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  events ShipmentEvent[]

  @@index([accountId])
  @@index([customerId])
  @@index([status])
  @@index([waybillId])
  @@index([checkoutSessionId])
  @@index([accountId, status])
  @@index([accountId, externalSource, externalRef])
}

model ShipmentEvent {
  id         String         @id @default(cuid())
  shipmentId String
  status     ShipmentStatus
  note       String?
  occurredAt DateTime
  raw        Json           @default("{}")
  createdAt  DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([shipmentId, occurredAt])
}

// =============================================================================
// PLATFORM PRIMITIVES — api keys, webhooks, audit log, courier config
// =============================================================================

/// HMAC API key for server-to-server access. The raw secret is shown
/// once on creation; we only persist a SHA-256 fingerprint.
///
/// Two key flavours:
///  - merchant key: `accountId` is the merchant's id; `partner` is null;
///    scopes typically `["read","write"]`.
///  - platform-admin key (Pattern 2 partner billing, e.g. Storlaunch
///    consuming Fulkruma): `partner` is the partner slug (e.g.
///    'storlaunch'), `accountId` is the platform-internal owner;
///    scopes include `fulkruma:platform:admin`. Honors the
///    `X-Fulkruma-On-Behalf-Of` header on signed requests.
model ApiKey {
  id            String    @id @default(cuid())
  accountId     String
  partner       String?   // partner slug for platform-admin keys
  name          String
  keyId         String    @unique // public id, e.g. AKIAFULK<random>
  secretHash    String    // sha256 of the secret, hex
  secretPreview String    // first 4 + last 4 chars of the secret, for UI display
  scopes        Json      @default("[\"read\",\"write\"]")
  lastUsedAt    DateTime?
  createdBy     String?   // huudis user_id
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@index([accountId])
  @@index([accountId, revokedAt])
  @@index([partner])
}

enum WebhookEventStatus {
  pending
  sent
  failed
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  accountId   String
  url         String
  secret      String   // shared HMAC secret used to sign outbound requests
  events      Json     @default("[\"*\"]") // e.g. ["fulkruma.shipment.*", "fulkruma.license.issued.v1"]
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  webhookEvents WebhookEvent[]

  @@index([accountId])
  @@index([accountId, active])
}

model WebhookEvent {
  id            String             @id @default(cuid())
  accountId     String
  endpointId    String
  type          String
  payload       Json
  status        WebhookEventStatus @default(pending)
  attempts      Int                @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  responseCode  Int?
  responseBody  String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([accountId, createdAt])
}

/// Pattern-2 partner-billing record. When a merchant comes through a
/// partner (Storlaunch / Ripllo), `provisionWorkspace` writes a row
/// here; the discountRate is frozen at provision time so a partner's
/// public rate change can't retroactively bill old merchants. Refuses
/// to re-route a merchant already provisioned by a different partner.
model PartnerWorkspace {
  accountId     String   @id
  partner       String   // 'storlaunch' | 'ripllo' | …
  discountRate  Float    @default(0.0)
  brandName     String?
  businessEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partner])
}

/// Append-only audit log. Backs the /dashboard/audit-log page.
model AuditLog {
  id         String   @id @default(cuid())
  accountId  String
  actorType  String   // "user" | "system" | "api_key"
  actorId    String?  // huudis user_id, or api key id
  actorEmail String?
  action     String   // "warehouse.created", "stock.adjusted", etc.
  targetType String?
  targetId   String?
  ip         String?
  userAgent  String?  @db.Text
  before     Json?
  after      Json?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([accountId, action])
  @@index([targetType, targetId])
}

/// Per-merchant Biteship config (the only courier integration in v1).
/// Stored encrypted at rest? Phase F decision — for v1 we store plaintext
/// and rely on row-level access control via accountId. One row per
/// merchant.
///
/// This row also doubles as the merchant's *shipping origin* — fields
/// `originAddress`, `contactName`, `contactPhone`, lat/lng, etc. were
/// originally an `Account` model in Storlaunch but Fulkruma keeps the
/// origin co-located with the courier config (one-row-per-merchant
/// invariant + simpler PrismaLike contract for the shipping service).
model BiteshipConfig {
  accountId    String   @id
  apiKey       String?
  defaultOriginId String? // CustomerAddress.id used as the default origin
  enabledCouriers Json   @default("[]") // ["jne","sicepat","ide","jnt","anteraja","pos","lion","ninja",...]
  defaultCourier  String?
  active       Boolean  @default(false)

  // Shipping origin — single canonical pickup address per merchant.
  // Populated via PATCH /shipping/origin (the dashboard form).
  originAddress           String?  @db.Text
  originProvince          String?
  originCity              String?
  originDistrict          String?
  originVillage           String?
  originPostal            String?
  originAreaId            String?
  originLat               Float?
  originLng               Float?
  originNote              String?  @db.Text
  contactName             String?
  contactPhone            String?
  // Mirror of origin pushed to Biteship — gives instant couriers
  // validated geocoding. Reset on origin update, recreated lazily.
  biteshipOriginLocationId String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
